{
  "name": "@mindlogic-ai/logician-ui",
  "version": "2.0.0-alpha.0",
  "description": "A comprehensive React design system built on Chakra UI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "USAGE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup || true",
    "build:watch": "tsup --watch",
    "prepublishOnly": "yarn build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests specified'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "optimize-icons": "node scripts/optimize-icons.js",
    "update-intl": "./scripts/get-lang-pack.sh"
  },
  "peerDependencies": {
    "@chakra-ui/react": "^2.8.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "framer-motion": "^10.0.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@mdxeditor/editor": "^1.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@types/lodash": "^4.17.20",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chakra-dayzed-datepicker": "^0.3.1",
    "date-fns": "^2.30.0",
    "katex": "^0.16.22",
    "libphonenumber-js": "^1.10.0",
    "lodash": "^4.17.21",
    "polished": "^4.3.0",
    "react-icons": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-pin-input": "^1.3.0",
    "react-select": "^5.8.0",
    "react-spinners": "^0.17.0",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^3.1.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-flexible-markers": "^1.3.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@chakra-ui/react": "^2.8.0",
    "@changesets/cli": "^2.27.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@next/eslint-plugin-next": "^15.5.0",
    "@storybook/addon-docs": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/react": "^8.5.0",
    "@storybook/react-vite": "^8.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/svgo": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^9.1.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "framer-motion": "^10.0.0",
    "prettier": "^3.6.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "storybook": "^8.5.0",
    "svgo": "^4.0.0",
    "tsc-alias": "^1.8.0",
    "tsup": "^8.5.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "chakra-ui",
    "ui-library",
    "typescript"
  ],
  "author": "Mindlogic AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindlogic-ai/logician-ui.git"
  },
  "bugs": {
    "url": "https://github.com/mindlogic-ai/logician-ui/issues"
  },
  "homepage": "https://github.com/mindlogic-ai/logician-ui#readme",
  "engines": {
    "node": ">=16.0.0",
    "yarn": ">=1.22.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
